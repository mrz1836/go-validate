# ================================================================================================
# 🏗️ PROJECT-SPECIFIC CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for go-validate
# Load Order: 90 (loaded near last, overrides all earlier defaults)
#
# This file contains configuration values unique to this project that differ
# from the shared defaults in 00-core.env and 10-*.env files.
#
# Override in: 99-local.env (local development only, not committed)
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

# Project Go versions (overrides 00-core.env defaults)
GO_PRIMARY_VERSION=1.25.x
GO_SECONDARY_VERSION=1.18.x

# ================================================================================================
# 🪄 MAGE-X GO VERSION OVERRIDES
# ================================================================================================

MAGE_X_GO_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.18.x

# ================================================================================================
# 📊 COVERAGE CONFIGURATION
# ================================================================================================

# Coverage Report Provider (codecov for this project)
GO_COVERAGE_PROVIDER=codecov

# Codecov Configuration
CODECOV_TOKEN_REQUIRED=true

# Coverage Exclusions (aligned with codecov.yml ignore paths)
GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,docs/,example/,examples/,mocks/,test/,testing/,testdata/,vendor/
